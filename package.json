{
	"name": "nextlint",
	"version": "1.5.5",
	"private": false,
	"author": "lynhan318",
	"workspaces": ["packages/*"],
	"description": "Nextlint is a WYSIWYG editor, writen in Svelte",
	"scripts": {
		"build": "bun run --filter=* build",
		"dev": "bun run --filter=* dev",
		"clean": "rm -rf node_modules ./**/*/{node_modules,build,dist,.turbo,.svelte-kit,.pnpm}",
		"version": "changeset version",
		"release": "bun build && changeset publish",
		"release:tag": "changeset tag"
	},
	"devDependencies": {},
	"keywords": [
		"Svelte",
		"Rich Text Editor",
		"WYSIWYG",
		"Nextlint",
		"tiptap",
		"javascript",
		"typescript",
		"gpt"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/sveltor/nextlint.git"
	},
	"license": "MIT",
	"type": "module"
}
