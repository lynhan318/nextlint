{
	"name": "@nextlint/svelte",
	"version": "3.1.0",
	"scripts": {
		"playground": "vite dev",
		"dev": "pnpm dev:package",
		"dev:package": "pnpm package -w",
		"build": "pnpm package",
		"build:css": "vite build",
		"deploy": "vite build",
		"preview": "vite preview",
		"package": "svelte-kit sync && svelte-package",
		"prepublishOnly": "npm run package",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --plugin-search-dir . --check . && eslint .",
		"format": "prettier --plugin-search-dir . --write .",
		"prepare": "svelte-kit sync "
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./EditorTheme": "./dist/EditorTheme.svelte"
	},
	"files": [
		"dist",
		"build",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"peerDependencies": {
		"svelte": ">=5.0.0"
	},
	"dependencies": {
		"@nextlint/core": "file:../core",
		"@floating-ui/dom": "^1.6.13",
		"@melt-ui/svelte": "^0.61.3",
		"@prosemirror-adapter/svelte": "^0.2.6",
		"@svelte-put/clickoutside": "^3.0.2",
		"@svelte-put/lockscroll": "^1.0.2",
		"@tiptap/core": "^2.11.9",
		"@tiptap/extension-bubble-menu": "^2.11.9",
		"@tiptap/extension-code-block": "^2.11.9",
		"@tiptap/extension-dropcursor": "^2.11.9",
		"@tiptap/extension-floating-menu": "^2.11.9",
		"@tiptap/extension-link": "^2.11.9",
		"@tiptap/extension-paragraph": "^2.11.9",
		"@tiptap/pm": "^2.11.9",
		"@tiptap/suggestion": "^2.11.9",
		"clsx": "^2.1.1",
		"hast-util-to-html": "^9.0.5",
		"highlight.js": "^11.11.1",
		"lucide-svelte": "^0.292.0",
		"prosemirror-highlight": "^0.5.0",
		"radash": "^11.0.0",
		"radix-icons-svelte": "^1.2.1",
		"shiki": "^1.29.2",
		"tailwind-merge": "^2.6.0",
		"tailwind-variants": "^0.1.20",
		"unsplash-js": "^7.0.19",
		"zeed-dom": "^0.10.11"
	},
	"devDependencies": {
		"@melt-ui/pp": "^0.1.4",
		"@sveltejs/adapter-static": "^3.0.0",
		"@sveltejs/kit": "^2.5.27",
		"@sveltejs/package": "^2.3.11",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"@tailwindcss/typography": "^0.5.16",
		"@typescript-eslint/eslint-plugin": "^6.21.0",
		"@typescript-eslint/parser": "^6.21.0",
		"autoprefixer": "^10.4.21",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte3": "^4.0.0",
		"postcss": "^8.5.3",
		"postcss-nested": "^6.2.0",
		"postcss-preset-env": "^9.6.0",
		"prettier": "^3.5.3",
		"prettier-plugin-svelte": "^3.3.3",
		"publint": "^0.2.12",
		"sass": "^1.87.0",
		"svelte": "^5.28.2",
		"svelte-check": "^4.0.0",
		"svelte-preprocess": "^6.0.0",
		"svelte-sequential-preprocessor": "^2.0.2",
		"tailwindcss": "^3.4.17",
		"tailwindcss-animate": "^1.0.7",
		"tslib": "^2.8.1",
		"typescript": "^5.8.3",
		"vite": "^6.3.4"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/sveltor/nextlint",
		"directory": "packages/svelte"
	},
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"keywords": [
		"Svelte",
		"Rich Text Editor",
		"WYSIWYG",
		"Nextlint",
		"tiptap",
		"javascript",
		"typescript",
		"gpt"
	]
}
